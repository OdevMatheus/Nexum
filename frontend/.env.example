# ==============================================================================
# NEXUM - Configuração do Ambiente do Frontend (Vite)
# Copie este arquivo para um arquivo chamado '.env' no mesmo diretório e
# preencha os valores reais de acordo com o seu ambiente de desenvolvimento.
# ==============================================================================

# URL da API do Backend
# Se não for fornecida, o app usará 'http://localhost:8080' em desenvolvimento
# e 'window.location.origin' em produção unificada.
VITE_API_URL=http://localhost:8080
