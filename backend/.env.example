# ==============================================================================
# NEXUM - Configuração do Ambiente do Backend (.env)!
# ==============================================================================

# ------------------------------------------------------------------------------
# Segurança & Autenticação (JWT)
# ------------------------------------------------------------------------------
# DEVE ter no mínimo 512 bits (64 caracteres).
# Exemplo de geração segura: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_key_minimum_512_bits_long_and_at_least_64_characters

# ------------------------------------------------------------------------------
# Serviço de Email (Resend)
# ------------------------------------------------------------------------------
# Chave de API do Resend para envio de notificações (obtenha em https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here

# Remetente de email verificado no Resend (ex: onboarding@resend.dev para contas gratuitas)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Endereço de email local para onde todos os emails de teste serão redirecionados
# (Obrigatório pára o plano FREE)
RESEND_OVERRIDE_TO_EMAIL=seu_email@dominio.com

# ------------------------------------------------------------------------------
# Integração Frontend-Backend
# ------------------------------------------------------------------------------
# URL base da aplicação usada nos links enviados por email (confirmação/reset).
# NOTA: O script 'run.cmd' já gerencia isso de forma 100% DINÂMICA:
#   -> Se você escolher a Opção [1] (Dev), o run.cmd define automaticamente http://localhost:5173
#   -> Se você escolher a Opção [2] (Unificado), o run.cmd define automaticamente http://localhost:8080
# Este valor abaixo só é usado caso você rode diretamente pela IDE ou manualmente pelo Maven:
APP_BASE_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# Controle de Inicialização & Carga de Dados (Seeder)
# ------------------------------------------------------------------------------
# IMPORTANTE: Se definido como 'true', limpa o banco de dados e recria os dados fictícios a cada inicialização.
# Defina como 'false' quando quiser preservar os dados que você mesmo cadastrou/modificou no app.
SEEDER_ENABLED=true

# ==============================================================================
# Variáveis Opcionais (Descomente caso queira customizar suas conexões locais)
# ==============================================================================
# PORT=8080
# LOG_LEVEL=INFO

# --- Banco de Dados (Padrões do Docker Compose) ---
# DATABASE_URL=jdbc:postgresql://localhost:5432/nexum_db
# DATABASE_USERNAME=nexum_user
# DATABASE_PASSWORD=nexum_password
# SHOW_SQL=false
# FORMAT_SQL=false

# --- Cache & Mensageria (Padrões do Docker Compose) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
